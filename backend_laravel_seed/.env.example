APP_NAME=DCBS API
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dcbs
DB_USERNAME=dcbs_user
DB_PASSWORD=strong_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

API_AUTH_PACKAGE=sanctum
API_AUTH_GUARD=sanctum

QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@dcbs.com"
MAIL_FROM_NAME="${APP_NAME}"

STATEMENT_MAX_SYNC_FILE_KB=2048
STATEMENT_MEMORY_LIMIT=512M
STATEMENT_TIME_LIMIT_SECONDS=300

TESSERACT_BINARY=tesseract
OCR_LANGUAGE=eng

AI_PARSER_API_KEY=
AI_PARSER_MODEL=gpt-4o-mini
AI_PARSER_TIMEOUT_SECONDS=30
